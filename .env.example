# Diamond Edge — Root-level environment variables
#
# Copy this to .env and fill in the values. .env is gitignored.
# For Next.js app-specific env vars, use apps/web/.env.local instead.

# The Odds API — used by both live ingestion and historical backfill
# Sign up: https://the-odds-api.com/
THE_ODDS_API_KEY=

# (Add others as needed: ANTHROPIC_API_KEY, SUPABASE_URL, etc.)

# ============================================================
# Diamond Edge — Environment Variables
# Copy to .env.local and fill in values for local development.
# Production values are set in Vercel environment settings.
# NEVER commit .env.local to version control.
# ============================================================

# ---- Feature flags (public — inlined into client bundle) ----
# Master switch for paid-tier surfaces (auth, billing, age-gate, geo-block,
# tier-gated pick fields, upgrade CTAs). Default `false` runs Diamond Edge as a
# free, no-auth informational service — every viewer sees Elite-equivalent
# pick depth. Set to `true` to restore the full subscription product. Paid-tier
# code is preserved in the tree under either setting (portfolio reference).
NEXT_PUBLIC_PAID_TIERS=false

# ---- Supabase (public — safe to expose to browser) ----
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---- Supabase (server-only — NEVER in client bundle) ----
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- Upstash Redis (server-only) ----
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ---- Stripe (server-only) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs for tier mapping (from Stripe dashboard)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...

# ---- Geo-blocking ----
# Comma-separated two-letter state codes where Diamond Edge is available.
# Update this env var (+ redeploy) when a new state goes ALLOW.
GEO_ALLOW_STATES=AZ,AR,CO,CT,DC,IL,IN,IA,KS,KY,LA,MD,MA,MI,MO,NJ,NY,NC,OH,PA,TN,VT,VA,WV,WY

# ---- Cron / internal routes ----
# Secret header value for Vercel Cron → internal API routes
CRON_SECRET=your-cron-secret-here

# ---- External APIs (server-only) ----
# The Odds API — https://the-odds-api.com/
ODDS_API_KEY=your-odds-api-key

# Anthropic — LLM rationale generation
ANTHROPIC_API_KEY=sk-ant-...
